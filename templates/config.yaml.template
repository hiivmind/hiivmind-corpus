# {{project_display_name}} Corpus Configuration
schema_version: 2

corpus:
  name: "{{project_name}}"
  display_name: "{{project_display_name}}"
  keywords:                    # Routing keywords for per-session discovery
    - "{{project_name}}"
{{#additional_keywords}}
    - "{{.}}"
{{/additional_keywords}}
  created_at: null

# Sources are added via hiivmind-corpus-add-source
# Each source has its own type and tracking
sources: []

# Example source configurations (for reference):
#
# Git repository:
# - id: "polars"
#   type: "git"
#   repo_url: "https://github.com/pola-rs/polars"
#   repo_owner: "pola-rs"
#   repo_name: "polars"
#   branch: "main"
#   docs_root: "docs/"
#   last_commit_sha: null
#   last_indexed_at: null
#
# llms.txt manifest (sites with structured LLM documentation):
# - id: "claude-code"
#   type: "llms-txt"
#   manifest:
#     url: "https://code.claude.com/docs/llms.txt"
#     last_hash: null
#     last_fetched_at: null
#   urls:
#     base_url: "https://code.claude.com/docs/en"
#     suffix: ".md"
#   cache:
#     enabled: true
#     strategy: "selective"  # full | selective | on-demand
#     sections: []
#   structure:
#     title: null
#     sections: []
#   last_indexed_at: null

index:
  format: "markdown"
  last_updated_at: null

# render: controls how render-index.sh turns index.yaml into markdown.
# Omit entirely for a single index.md (default). Uncomment for a tiered corpus.
# Tiering is a render-time concern — there is always exactly one index.yaml.
# render:
#   strategy: tiered            # single (default) | tiered
#   quick_reference:            # optional: entry IDs pinned at the top of index.md
#     - "mysource:getting-started/install.md"
#   sections:                   # required when strategy: tiered
#     - id: getting-started     # slug; produces index-getting-started.md
#       title: "Getting Started"
#       description: "First steps - installation, signup, first deploy"

settings:
  include_patterns:
    - "**/*.md"
    - "**/*.mdx"
  exclude_patterns:
    - "**/_*.md"
    - "**/_snippets/**"
